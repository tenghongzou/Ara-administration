/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=63072000; includeSubDomains
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self' ws://localhost:* wss://localhost:* ws://*.pervive.cc wss://*.pervive.cc https://*.pervive.cc; frame-ancestors 'none'

# HTML 不快取，確保每次取得最新版本
/*.html
  Cache-Control: no-cache, no-store, must-revalidate

/index.html
  Cache-Control: no-cache, no-store, must-revalidate

# 靜態資源使用長期快取（檔名包含 hash）
/_app/*
  Cache-Control: public, max-age=31536000, immutable
